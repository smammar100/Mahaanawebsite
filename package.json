{
  "name": "mahaana-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "all-servers": "concurrently -n next,sanity -c cyan,magenta \"npm run dev\" \"npx sanity dev\"",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "schema:extract": "sanity schema extract --path public/studio/static/schema.json",
    "schema:deploy": "node scripts/schema-deploy.cjs",
    "sanity:manifest": "sanity manifest extract --path public/studio/static",
    "sanity:generate": "npm run schema:extract && npm run sanity:manifest",
    "sanity:verify-env": "node scripts/verify-sanity-env.cjs",
    "revalidate:verify-env": "node scripts/verify-revalidation-env.cjs",
    "sanity:studio-deploy": "node scripts/studio-deploy.cjs",
    "sanity:transform-reviews": "node scripts/transform-app-review-ndjson.mjs",
    "sanity:import-reviews": "node scripts/import-reviews-dataset.mjs",
    "sanity:sync": "npm run sanity:generate && npm run schema:deploy",
    "sanity:deploy-all": "npm run sanity:verify-env && npm run sanity:sync && npm run sanity:studio-deploy",
    "import:investor-education": "tsx scripts/import-investor-education-csv.ts",
    "import:help-center-faqs": "tsx scripts/import-help-center-faqs-csv.ts",
    "import:post": "npx tsx scripts/import-roshan-post.ts",
    "import:html": "npx tsx scripts/import-html-article.ts",
    "import:html:preview": "npx tsx scripts/import-html-article.ts --preview",
    "repair:job-pt": "npx tsx scripts/repair-job-portable-text.ts",
    "repair:job-pt:dry": "npx tsx scripts/repair-job-portable-text.ts --dry-run"
  },
