# MICF real-time fund data API (optional; defaults to production Azure FD URL if unset)
# NEXT_PUBLIC_FUND_DATA_API_BASE_URL=https://fdepprodmahaana-gkb9bdeehudhdedy.z02.azurefd.net

# Sanity (get token from https://www.sanity.io/manage → API → Tokens)
NEXT_PUBLIC_SANITY_PROJECT_ID=ctfatnb0
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=
# For import scripts (e.g. import-roshan-post): add to .env.local without overwriting
SANITY_WRITE_TOKEN=
# Deploy token for schema deploy + hosted Studio deploy (npm run schema:deploy, npm run sanity:studio-deploy, npm run sanity:deploy-all).
# Use a token with Editor/deploy permissions for project ctfatnb0 — read-only tokens will fail with missing grant (e.g. deployStudio, project.read).
SANITY_AUTH_TOKEN=
# API version for Sanity client
SANITY_API_VERSION=2024-01-01
# Canonical studio URL; also set in Sanity Manage so Dashboard can discover the studio
NEXT_PUBLIC_SANITY_STUDIO_URL=https://mahaana.netlify.app/studio

# On-demand ISR: Sanity webhook → POST /api/revalidate (see docs/sanity.md “Cache revalidation”).
# Set the SAME value in Netlify env and in the Sanity webhook Authorization header: Bearer <value>
# Generate a long random string; do not commit real secrets to git.
REVALIDATION_SECRET=
